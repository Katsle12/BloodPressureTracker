<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:data="clr-namespace:Blood_Pressure_Tracker.Data"
             xmlns:viewModel="clr-namespace:Blood_Pressure_Tracker.ViewModel"
             x:Class="Blood_Pressure_Tracker.MainPage"
             x:DataType="viewModel:MainPageViewModel">

    <ScrollView>
        <VerticalStackLayout>
            <Label Text="Record measurement" HorizontalOptions="Center" VerticalOptions="Start"/>
            
            <Label Text="Systolic value"/>
            <Entry Keyboard="Numeric" ReturnType="Next" Text="{Binding Measurement.Systolic}"/>
            <Label Text="Diastolic value"/>
            <Entry Keyboard="Numeric" ReturnType="Next" Text="{Binding Measurement.Diastolic}"/>
            <Label Text="Pulse value"/>
            <Entry Keyboard="Numeric" ReturnType="Done" Text="{Binding Measurement.Pulse}" />
            
            <Button Text="Record values" Command="{Binding RecordMeasurementCommand}"/>
            
            <Label Text="{Binding AvgText}" Margin="0,10,0,10"/>
            
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                <Button Command="{Binding LoadFileCommand}" Text="Load data from csv file"/>
                <Button Command="{Binding SaveFileCommand}" Text="Save file to csv"/>
            </HorizontalStackLayout>
            
            
            <CollectionView ItemsSource="{Binding CurrentMeasurements}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="data:Measurement">
                        <HorizontalStackLayout Spacing="1,1" HorizontalOptions="Center">
                            <Label Text="{Binding Systolic}"/>
                            <Label Text="{Binding Diastolic}"/>
                            <Label Text="{Binding Pulse}"/>
                        </HorizontalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
